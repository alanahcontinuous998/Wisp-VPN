<Application x:Class="WispVpn.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <ResourceDictionary>
      <SolidColorBrush x:Key="BackgroundBrush" Color="#0D1117"/>
      <SolidColorBrush x:Key="SurfaceBrush" Color="#161B22"/>
      <SolidColorBrush x:Key="BorderBrush" Color="#30363D"/>
      <SolidColorBrush x:Key="TextBrush" Color="#C9D1D9"/>
      <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8B949E"/>
      <SolidColorBrush x:Key="AccentBrush" Color="#58A6FF"/>
      <SolidColorBrush x:Key="AccentGreenBrush" Color="#3FB950"/>
    </ResourceDictionary>
  </Application.Resources>
</Application>
